      "title": "FormatTemplate",
      "properties": {
        "name": "FormatTemplate",
        "type": "standard",
        "template": "{% set n = cur_keyframes|length %}\n{% set cols = ceil(sqrt(n))|int %}\n{% set rows = ceil(n / cols)|int %}\n{% set orientation = \"VERTICAL (portrait, 9:16)\" %}\nGenerate a single {{ orientation }} image containing a {{ cols }}x{{ rows }} grid of animation keyframes for a music video.\n\nIMAGE ORIENTATION: {{ orientation }}.\n\nCHARACTER BIBLE:\n{% for char in character_bible %}\n{{ char.name }}: {{ char.description }}\n{% endfor %}\n\nSTYLE GUIDE:\n{{ style_guide }}\n\nGRID LAYOUT:\n{{ cols }} columns x {{ rows }} rows. Panels must be flush edge-to-edge with NO gaps, borders, margins, or spacing between them.\nEach panel occupies exactly 1/{{ cols }} of the width and 1/{{ rows }} of the height.\nEach panel is a {{ orientation }} frame.\nAll panels must share the same art style, color palette, and character designs for visual consistency.\n\nPANELS:\n{% for kf in cur_keyframes %}\n    {% set r = loop.index0 // cols + 1 %}\n    {% set c = loop.index0 % cols + 1 %}\nPanel ({{ r }},{{ c }}) \u2014 Keyframe {{ kf.idx }}: {{ kf.image_prompt }}\n{% endfor %}\n\nIMPORTANT:\nGenerate exactly one {{ orientation }} image with all {{ n }} panels arranged in a {{ cols }}x{{ rows }} grid with NO borders or gaps.\nMaintain consistent character appearances and art style across all panels.",
        "output_key": "grid_prompt"
      }
    },
